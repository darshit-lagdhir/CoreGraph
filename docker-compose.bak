services:
  db:
    image: postgres:15-alpine
    container_name: coregraph_postgres
    hostname: db-vj92.private.coregraph
    restart: always
    environment:
      POSTGRES_USER: admin
      POSTGRES_PASSWORD: password123
      POSTGRES_DB: coregraph_db
      POSTGRES_INITDB_ARGS: "--auth-host=scram-sha-256 --auth-local=scram-sha-256"
      POSTGRES_HOST_AUTH_METHOD: "scram-sha-256"
    command: postgres -c "listen_addresses='*'" -c "hba_file=/etc/postgresql/pg_hba.conf"
    ports:
      - "127.0.0.1:5433:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./infrastructure/pg_hba.conf:/etc/postgresql/pg_hba.conf:ro
    networks:
      coregraph_private:

  redis:
    image: redis:7-alpine
    container_name: coregraph_redis
    restart: always
    command: redis-server /usr/local/etc/redis/redis.conf
    volumes:
      - redis_data:/data
      - ./infrastructure/redis.conf:/usr/local/etc/redis/redis.conf:ro
    networks:
      coregraph_private:

  api:
    build:
      context: .
      dockerfile: infrastructure/Dockerfile
    container_name: coregraph_api
    restart: always
    command: ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "4", "--loop", "uvloop", "--http", "httptools"]
    ports:
      - "127.0.0.1:8000:8000"
    env_file:
      - .env
    networks:
      coregraph_public:
      coregraph_private:
    depends_on:
      - db
      - redis

  worker:
    build:
      context: .
      dockerfile: infrastructure/Dockerfile
    container_name: coregraph_worker
    restart: always
    command: ["celery", "-A", "worker", "worker", "--loglevel=info"]
    env_file:
      - .env
    networks:
      coregraph_private:
    depends_on:
      - db
      - redis
      - api

volumes:
  postgres_data:
  redis_data:

networks:
  coregraph_public:
    driver: bridge
    ipam:
      config:
        - subnet: 172.20.0.0/16
  coregraph_private:
    driver: bridge
    internal: true
    ipam:
      config:
        - subnet: 172.21.0.0/16
  default:
    driver: none
